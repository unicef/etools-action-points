{
  "name": "apd",
  "version": "3.0.0",
  "contributors": [
    "The eTools Team"
  ],
  "type": "module",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git@github.com:unicef/etools-action-points"
  },
  "bugs": {
    "url": "https://github.com/unicef/etools-action-points/issues"
  },
  "description": "Action Points Dashboard for UNICEF eTools",
  "scripts": {
    "build": "export NODE_OPTIONS=--max_old_space_size=4096 && rollup -c rollup-prod.config.js --configPlugin @rollup/plugin-commonjs",
    "tsToJs": "tsc --skipLibCheck || true",
    "start": "rm -rf ./src && rollup -c rollup-dev.config.js -w --configPlugin @rollup/plugin-commonjs",
    "lint:eslint": "eslint src_ts/**",
    "format:eslint": "eslint src_ts/** --fix",
    "lint": "pnpm run lint:eslint",
    "format": "pnpm run format:eslint",
    "generate:icons": "pnpm --dir node_modules/@unicef-polymer/etools-unicef run generate-icons -- --output=$(pwd)/assets/icons/ --icons=$(pwd)/assets/icons/icons.js"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "2.20.1",
    "@types/lodash-es": "^4.17.7",
    "@unicef-polymer/etools-modules-common": "workspace:*",
    "@unicef-polymer/etools-piwik-analytics": "workspace:*",
    "@unicef-polymer/etools-types": "workspace:*",
    "@unicef-polymer/etools-unicef": "workspace:*",
    "@unicef-polymer/etools-utils": "workspace:*",
    "dayjs": "^1.11.13",
    "dexie": "^3.2.2",
    "linkify-string": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "lit": "^3.3.1",
    "lodash-es": "^4.17.23",
    "redux": "^4.2.0",
    "redux-thunk": "^2.4.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.16.0",
    "@rollup/plugin-commonjs": "28.0.1",
    "@rollup/plugin-dynamic-import-vars": "^2.1.5",
    "@rollup/plugin-node-resolve": "15.3.0",
    "@rollup/plugin-terser": "0.4.4",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "braces": ">=3.0.3",
    "esbuild": "^0.25.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-html": "^8.1.2",
    "eslint-plugin-lit": "^1.15.0",
    "eslint-plugin-lit-a11y": "^4.1.4",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.13.0",
    "js-yaml": ">=4.1.1",
    "prettier": "~3.4.2",
    "rollup": "4.28.1",
    "rollup-plugin-copy": "3.4.0",
    "rollup-plugin-delete": "3.0.2",
    "rollup-plugin-esbuild": "6.1.1",
    "rollup-plugin-license": "3.5.3",
    "rollup-plugin-livereload": "2.0.5",
    "rollup-plugin-serve": "3.0.0",
    "rollup-plugin-workbox": "^8.1.3",
    "svg-sprite": "^2.0.4",
    "typescript": "5.3.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-musl": "^4.28.1"
  }
}
